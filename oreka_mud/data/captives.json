  "templates": {
    "scout": {
      "name_pool": ["the scout", "the outrider", "the tracker"],
      "description": "A weathered figure in travel-stained leathers. Eyes watchful, bearings clipped.",
      "hooks": ["rescued while tracking a raiding party", "captured mid-patrol", "ambushed at a water stop"],
      "valid_family_factions": ["far_riders", "circle_of_deeproot", "brotherhood_of_steppe"]
    },
    "farmer": {
      "name_pool": ["the farmer", "the herder", "the homesteader"],
      "description": "A careworn figure with hands that show decades of honest labor. Dust still clings to their clothes.",
      "hooks": ["taken from a raided farmstead", "grabbed while traveling to market", "caught in a cult's tithe-round"],
      "valid_family_factions": ["brotherhood_of_steppe", "trade_houses", "circle_of_deeproot"]
    },
    "merchant": {
      "name_pool": ["the trader", "the factor's agent", "the caravan-master"],
      "description": "A well-dressed figure whose fine cloak is now stained. They have the calm of someone used to making deals.",
      "hooks": ["caravan taken on the road", "smuggler's debt come due", "hostage of a trade dispute"],
      "valid_family_factions": ["trade_houses", "chainless_legion", "sand_wardens"]
    },
    "child": {
      "name_pool": ["the child", "the young one", "the apprentice"],
      "description": "A small frightened figure, clearly in far over their head. They will not meet your eyes.",
      "hooks": ["abducted from a family homestead", "lost and caught by the wrong patrol", "taken as leverage against their parents"],
      "valid_family_factions": ["any"]
    },
    "scholar": {
      "name_pool": ["the scholar", "the scribe", "the translator"],
      "description": "A bookish figure in worn robes, fingers stained with ink. They regard their captors with quiet hatred.",
      "hooks": ["captured for forced translation work", "taken for their knowledge of a specific site", "grabbed en route to a library"],
      "valid_family_factions": ["trade_houses", "silent_concord", "circle_of_deeproot"]
    }
  },

  "reward_pools": {
    "masterwork_mundane": {
      "description": "Masterwork mundane items appropriate for levels 1-8",
